rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function isAdmin() {
      return signedIn() && userDoc(request.auth.uid).data.role == 'ADMIN';
    }

    function safeGameHistory(value) {
      return value is list && value.size() <= 100;
    }

    function validUserCreate(data) {
      return data.keys().hasOnly([
        'nickname',
        'email',
        'avatarUrl',
        'country',
        'hearts',
        'bestTime',
        'role',
        'lastDailyHeart',
        'agreedToTerms',
        'banned',
        'gameHistory',
        'referralCode',
        'referredBy',
        'referralRewardGranted',
        'rewardedVideoStreak',
        'applixirUserId',
        'updatedAt'
      ])
        && data.nickname is string
        && data.email is string
        && data.avatarUrl is string
        && data.country is string
        && data.hearts is int
        && data.hearts >= 0
        && data.hearts <= 3
        && data.bestTime == null
        && data.role == 'USER'
        && data.lastDailyHeart == null
        && data.agreedToTerms is bool
        && data.banned == false
        && safeGameHistory(data.gameHistory)
        && data.referralCode is string
        && (data.referredBy == null || data.referredBy is string)
        && data.referralRewardGranted == false
        && data.rewardedVideoStreak is int
        && data.rewardedVideoStreak == 0
        && data.applixirUserId is string
        && data.applixirUserId.matches('^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$');
    }

    function validSelfUserUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'nickname',
        'email',
        'avatarUrl',
        'country',
        'agreedToTerms',
        'applixirUserId',
        'gameHistory',
        'updatedAt'
      ])
        && request.resource.data.nickname is string
        && request.resource.data.email is string
        && request.resource.data.avatarUrl is string
        && request.resource.data.country is string
        && request.resource.data.agreedToTerms is bool
        && safeGameHistory(request.resource.data.gameHistory)
        && request.resource.data.hearts == resource.data.hearts
        && request.resource.data.bestTime == resource.data.bestTime
        && request.resource.data.role == resource.data.role
        && request.resource.data.lastDailyHeart == resource.data.lastDailyHeart
        && request.resource.data.banned == resource.data.banned
        && request.resource.data.referralCode == resource.data.referralCode
        && request.resource.data.referredBy == resource.data.referredBy
        && request.resource.data.referralRewardGranted == resource.data.referralRewardGranted
        && request.resource.data.rewardedVideoStreak == resource.data.rewardedVideoStreak
        && request.resource.data.applixirUserId is string
        && request.resource.data.applixirUserId.matches('^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$')
        && (
          !('applixirUserId' in resource.data) ||
          resource.data.applixirUserId == null ||
          request.resource.data.applixirUserId == resource.data.applixirUserId
        );
    }

    function validSupportTicketCreate(data) {
      return data.keys().hasOnly([
        'userId',
        'email',
        'subject',
        'message',
        'status',
        'createdAt'
      ])
        && data.userId == request.auth.uid
        && data.email is string
        && data.email.size() <= 254
        && data.subject is string
        && data.subject.size() > 0
        && data.subject.size() <= 120
        && data.subject.matches('.*\\S.*')
        && data.message is string
        && data.message.size() > 0
        && data.message.size() <= 5000
        && data.message.matches('.*\\S.*')
        && data.status == 'open'
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create: if isSelf(userId) && validUserCreate(request.resource.data);
      allow update: if isAdmin() || (isSelf(userId) && validSelfUserUpdate());
      allow delete: if false;
    }

    match /leaderboard/{entryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /stats/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adRewards/{rewardId} {
      allow read: if signedIn() && (
        request.auth.uid == resource.data.userId ||
        isAdmin()
      );
      allow create, update, delete: if false;
    }

    match /referralRewards/{rewardId} {
      allow read: if signedIn() && (
        request.auth.uid == resource.data.referredUserId ||
        request.auth.uid == resource.data.referrerId ||
        isAdmin()
      );
      allow create, update, delete: if false;
    }

    match /supportTickets/{ticketId} {
      allow create: if signedIn() && validSupportTicketCreate(request.resource.data);
      allow read: if signedIn() && (
        request.auth.uid == resource.data.userId ||
        isAdmin()
      );
      allow update, delete: if isAdmin();
    }
  }
}
