VITE_SITE_URL=https://your-production-domain.example
VITE_SUPPORT_EMAIL=support@example.com
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

VITE_APPLIXIR_API_KEY=your_real_applixir_game_api_key
VITE_APPLIXIR_SERVER_VALIDATION=true
VITE_APPLIXIR_SCRIPT_SRC=/lib/player.js

# Server-side only. Set this as a Firebase Functions secret, not as a public Vite env var.
APPLIXIR_CALLBACK_SECRET=your_applixir_callback_secret
